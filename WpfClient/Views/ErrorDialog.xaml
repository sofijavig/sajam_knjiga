<Window x:Class="WpfClient.Views.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Error_WindowTitle}"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F6F7FB"
        FontFamily="Segoe UI"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- Palette (match app) -->
        <SolidColorBrush x:Key="Primary" Color="#FF8F4F"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C2185B"/>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Hover" Color="#F3F4F6"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Opacity="0.12"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <!-- Buttons -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EDEEF2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#AD1457"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource Primary}"
                CornerRadius="16"
                Padding="14,12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" FontSize="18" Margin="0,0,10,0" Foreground="White"/>
                <StackPanel>
                    <TextBlock Text="{Binding DialogTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding DialogSubtitle, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="#FFE4EC"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content card -->
        <Border Grid.Row="1"
                Background="{StaticResource Card}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="44" Height="44"
                        CornerRadius="12"
                        Background="#FFF1F6"
                        VerticalAlignment="Top"
                        Margin="0,0,12,0">
                    <TextBlock Text="!" FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryDark}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Details, RelativeSource={RelativeSource AncestorType=Window}}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource SubText}"
                               FontSize="12"
                               Margin="0,10,0,0"
                               Visibility="{Binding DetailsVisibility, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BtnOk"
                    Content="{DynamicResource Common_OK}"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnOk_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>