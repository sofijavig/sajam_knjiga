<Window x:Class="WpfClient.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource About_Title}"
        Width="500" Height="450"
        WindowStartupLocation="CenterOwner"
        Background="#F6F7FB"
        FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Primary" Color="#F5B0CB"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Opacity="0.12"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C2185B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#AD1457"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource Card}"
                CornerRadius="16"
                Padding="20"
                Margin="20"
                Effect="{StaticResource CardShadow}">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="{DynamicResource About_Header}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource Text}"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="{DynamicResource About_Description}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource SubText}"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource About_AuthorsHeader}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="{DynamicResource About_Author1}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author2}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author3}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author4}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author5}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author6}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author7}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author8}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author9}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author10}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author11}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        <TextBlock Text="{DynamicResource About_Author12}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Content="{DynamicResource BtnClose}"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>