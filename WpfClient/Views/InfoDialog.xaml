<Window x:Class="WpfClient.InfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Info_WindowTitle}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Background="#F6F7FB"
        FontFamily="Segoe UI">

    <Border CornerRadius="16"
            BorderBrush="#FF8F4F"
            BorderThickness="2"
            Background="White"
            Padding="20">

        <StackPanel Width="260">

            <TextBlock Text="ℹ️"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="TxtMessage"
                       TextAlignment="Center"
                       FontSize="14"
                       Margin="0,0,0,18"
                       TextWrapping="Wrap"/>

            <Button Content="{DynamicResource Common_OK}"
                    Width="90"
                    Height="34"
                    HorizontalAlignment="Center"
                    Background="#FF8F4F"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Ok_Click"/>
        </StackPanel>
    </Border>
</Window>