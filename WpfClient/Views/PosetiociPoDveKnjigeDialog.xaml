<Window x:Class="WpfClient.Views.PosetiociPoDveKnjigeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WinVisitorsTwoBooksTitle}"
        Width="920" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#BF79C7"/>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Hover" Color="#F3F4F6"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Opacity="0.12"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFB"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="12,9"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF1F6"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FCE4EC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9C50B2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#7A2F94"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource Primary}"
                CornerRadius="16"
                Padding="14,12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource VisitorsTwoBooks_Header}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="TxtSub"
                           Foreground="#FFE4EC"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ComboBox izbor + dugme -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{DynamicResource VisitorsTwoBooks_FirstBookLabel}" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbPrvaKnjiga" Width="300" DisplayMemberPath="Naziv"/>
            </StackPanel>

            <StackPanel Margin="12,0,0,0">
                <TextBlock Text="{DynamicResource VisitorsTwoBooks_SecondBookLabel}" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbDrugaKnjiga" Width="300" DisplayMemberPath="Naziv"/>
            </StackPanel>

            <Button Content="{DynamicResource VisitorsTwoBooks_ShowBtn}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="12,0,0,0"
                    Click="BtnPrikaziPosetioce_Click"/>
        </StackPanel>

        <!-- Search -->
        <DockPanel Grid.Row="2" LastChildFill="True" Margin="0,0,0,12">
            <TextBlock Text="🔍" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}"/>
            <TextBox x:Name="TbSearch" Width="400" KeyUp="TbSearch_KeyUp"/>
            <Button Content="{DynamicResource BtnClear}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="12,0,0,0"
                    Click="BtnClear_Click"/>
        </DockPanel>

        <!-- Tabovi -->
        <TabControl Grid.Row="3">
            <TabItem Header="{DynamicResource VisitorsTwoBooks_TabBothWish}">
                <DataGrid x:Name="DgObeKnjige" AutoGenerateColumns="False" Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource ColVisitorsCardNumber}" Binding="{Binding CK}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource ColFirstName}" Binding="{Binding Ime}" Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource ColLastName}" Binding="{Binding Prezime}" Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource ColStatus}" Binding="{Binding Status}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="{DynamicResource VisitorsTwoBooks_TabBoughtFirstNotSecond}">
                <DataGrid x:Name="DgKupiliPrvu" AutoGenerateColumns="False" Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource ColVisitorsCardNumber}" Binding="{Binding CK}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource ColFirstName}" Binding="{Binding Ime}" Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource ColLastName}" Binding="{Binding Prezime}" Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource ColStatus}" Binding="{Binding Status}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>