<Window x:Class="WpfClient.AutorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AuthorsTitle}"
        Width="820"
        Height="650"
        SizeToContent="Manual"
        MaxHeight="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#F6F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#A6EBA2"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#2E7D32"/>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Hover" Color="#F3F4F6"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Opacity="0.12"/>

        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid x:Name="Root" Margin="0,0,25,0" Cursor="Hand">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Margin="10,0,10,10"/>
                            <Border x:Name="Indicator"
                                    Height="3"
                                    Background="{StaticResource PrimaryDark}"
                                    VerticalAlignment="Bottom"
                                    Visibility="Collapsed"
                                    CornerRadius="1.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource SubText}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabControl" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Background="Transparent"/>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SubText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Hover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,12">

                <!-- Header -->
                <Border Background="{StaticResource Primary}" CornerRadius="16" Padding="14,12" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✍️" FontSize="18" Margin="0,0,10,0" Foreground="White"/>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource AuthorsTitle}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{DynamicResource AutorDialogSubtitle}" Foreground="White" Opacity="0.9" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource Card}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20"
                        Effect="{StaticResource CardShadow}">

                    <TabControl Style="{StaticResource ModernTabControl}" Background="Transparent" BorderThickness="0">

                        <!-- Tab: Info -->
                        <TabItem Header="{DynamicResource TabInfo}" Style="{StaticResource ModernTabItem}">
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{DynamicResource ColAuthorsIdCard}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbLK" Grid.Row="0" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="1" Text="{DynamicResource ColFirstName}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbIme" Grid.Row="1" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="2" Text="{DynamicResource ColLastName}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbPrezime" Grid.Row="2" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="3" Text="{DynamicResource ColAuthorsBirthDate}" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="DpDatRodj" Grid.Row="3" Grid.Column="1" Margin="0,4" SelectedDateChanged="AnyChanged"/>

                                <TextBlock Grid.Row="4" Text="{DynamicResource ColEmail}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbMail" Grid.Row="4" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="5" Text="{DynamicResource ColPhone}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbTelefon" Grid.Row="5" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="6" Text="{DynamicResource ColYearsExperience}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbGodIsk" Grid.Row="6" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="7" Text="{DynamicResource ColStreet}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbUlica" Grid.Row="7" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="8" Text="{DynamicResource ColNumber}" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="TbBroj" Grid.Row="8" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="9" Text="{DynamicResource ColCityCountry}" Style="{StaticResource FormLabel}"/>
                                <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                                    <TextBox x:Name="TbGrad" Width="155" Margin="0,0,10,0" TextChanged="AnyChanged"/>
                                    <TextBox x:Name="TbDrzava" Width="155" TextChanged="AnyChanged"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- Tab: Books -->
                        <TabItem Header="{DynamicResource TabBooks}" Style="{StaticResource ModernTabItem}">
                            <StackPanel Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="{DynamicResource BtnAddBook}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,10,0"
                                            Click="BtnDodajKnjigu_Click"/>
                                    <Button Content="{DynamicResource BtnRemoveBook}"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnUkloniKnjigu_Click"/>
                                </StackPanel>

                                <Border CornerRadius="12"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1"
                                        Background="White"
                                        SnapsToDevicePixels="True">
                                    <DataGrid x:Name="DgKnjigeAutora"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              GridLinesVisibility="None"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              AlternationCount="2"
                                              AlternatingRowBackground="#F8FAFC"
                                              SelectionMode="Single"
                                              MinRowHeight="34">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="{DynamicResource ColBooksISBN}" Binding="{Binding ISBN}" Width="120"/>
                                            <DataGridTextColumn Header="{DynamicResource ColBooksTitle}" Binding="{Binding Naziv}" Width="*"/>
                                            <DataGridTextColumn Header="{DynamicResource ColBooksYear}" Binding="{Binding GodinaIzdanja}" Width="120"/>
                                            <DataGridTextColumn Header="{DynamicResource ColBooksGenre}" Binding="{Binding Zanr}" Width="140"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <Border Grid.Row="1" Background="#F6F7FB" Padding="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnPotvrdi"
                        Content="{DynamicResource BtnConfirm}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,0"
                        Click="BtnPotvrdi_Click"
                        IsEnabled="False"/>
                <Button Content="{DynamicResource BtnCancel}"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
        
    </Grid>
</Window>