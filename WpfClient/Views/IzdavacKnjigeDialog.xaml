<Window x:Class="WpfClient.Views.IzdavacKnjigeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource BtnShowBooksOfPublisher}"
        Width="900"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#F6F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- BOJE -->
        <SolidColorBrush x:Key="Primary" Color="#3f4999"/>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Hover" Color="#EEF0FF"/>

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.15"/>

        <!-- DataGrid stil -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFB"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Hover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Primary}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔵 PLAVI HEADER -->
        <Grid Grid.Row="0"
              Background="{StaticResource Primary}">

            <StackPanel VerticalAlignment="Center"
                        Margin="30,0,0,0">

                <TextBlock x:Name="TxtTitle"
                           Text="{DynamicResource BtnShowBooksOfPublisher}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock x:Name="TxtSubtitle"
                           Foreground="#D6DAFF"
                           FontSize="13"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="1"
              Margin="20">

            <Border Background="{StaticResource Card}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="16"
                    Effect="{StaticResource CardShadow}">

                <DataGrid x:Name="dgKnjige"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Books_Name}"  Binding="{Binding Naziv}"         Width="2*"/>
                        <DataGridTextColumn Header="{DynamicResource Books_ISBN}"  Binding="{Binding ISBN}"          Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Books_Genre}" Binding="{Binding Zanr}"          Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Books_Year}"  Binding="{Binding GodinaIzdanja}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Books_Price}" Binding="{Binding Cena}"          Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Books_Pages}" Binding="{Binding BrojStrana}"    Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>

        </Grid>

    </Grid>
</Window>