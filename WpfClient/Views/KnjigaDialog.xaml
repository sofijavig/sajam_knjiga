<Window x:Class="WpfClient.Views.KnjigaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WinBookTitle}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#F6F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Same palette as main -->
        <SolidColorBrush x:Key="Primary" Color="#A2E7EB"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C2185B"/>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Hover" Color="#F3F4F6"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Opacity="0.12"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SubText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Buttons -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EDEEF2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#AD1457"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button (+ / -) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EDEEF2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReadonlyTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#FAFAFB"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource Primary}"
                CornerRadius="16"
                Padding="14,12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📚" FontSize="18" Margin="0,0,10,0" Foreground="White"/>
                <StackPanel>
                    <TextBlock Text="{DynamicResource BooksTitle}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{DynamicResource BookDialogSubtitle}"
                               Foreground="#FFE4EC"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Form card -->
        <Border Grid.Row="1"
                Background="{StaticResource Card}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="290"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColBooksISBN}"/>
                <TextBox x:Name="TbISBN" Grid.Row="0" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColBooksTitle}"/>
                <TextBox x:Name="TbNaziv" Grid.Row="1" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColBooksGenre}"/>
                <TextBox x:Name="TbZanr" Grid.Row="2" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource BookPublisher}"/>
                <TextBox x:Name="TbIzdavac" Grid.Row="3" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource BookPriceRsd}"/>
                <TextBox x:Name="TbCena" Grid.Row="4" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColBooksYear}"/>
                <TextBox x:Name="TbGodina" Grid.Row="5" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource BookPages}"/>
                <TextBox x:Name="TbBrojStrana" Grid.Row="6" Grid.Column="1" Margin="0,4" TextChanged="AnyChanged"/>

                <!-- AUTORI * -->
                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource BookAuthorsRequired}"/>

                <Grid Grid.Row="7" Grid.Column="1" Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="LbAutori"
                             Height="78"
                             BorderBrush="{StaticResource Border}"
                             BorderThickness="1"
                             Background="#FAFAFB"
                             Padding="6"
                             SelectionMode="Single"
                             DisplayMemberPath="DisplayName"
                             SelectionChanged="LbAutori_SelectionChanged"/>

                    <Button x:Name="BtnAddAutor"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Content="+"
                            Style="{StaticResource IconButton}"
                            Click="BtnAddAutor_Click"/>

                    <Button x:Name="BtnRemoveAutor"
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="–"
                            Style="{StaticResource IconButton}"
                            Click="BtnRemoveAutor_Click"/>
                </Grid>

            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">

            <Button x:Name="BtnPotvrdi"
                    Content="{DynamicResource BtnConfirm}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,10,0"
                    Click="BtnPotvrdi_Click"
                    IsEnabled="False"/>

            <Button Content="{DynamicResource BtnCancel}"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>