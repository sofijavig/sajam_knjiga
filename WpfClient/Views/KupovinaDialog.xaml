<Window x:Class="WpfClient.Views.KupovinaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Kupovina_Title}"
        Width="480" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- BOJE -->
        <SolidColorBrush x:Key="Primary" Color="#f7c779"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#eba83d"/>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Hover" Color="#F3F4F6"/>

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          ShadowDepth="2"
                          Opacity="0.12"/>

        <!-- Label -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <!-- DatePicker -->
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,3,10,0"/>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EDEEF2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D99121"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource Primary}"
                CornerRadius="16"
                Padding="16"
                Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛒"
                           FontSize="18"
                           Margin="0,0,10,0"
                           Foreground="White"/>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Kupovina_HeaderTitle}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{DynamicResource Kupovina_HeaderSubtitle}"
                               Foreground="#f5ecdf"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Card -->
        <Border Grid.Row="1"
                Background="{StaticResource Card}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18"
                Effect="{StaticResource CardShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ISBN -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource FormLabel}"
                           Text="{DynamicResource Kupovina_LabelIsbn}"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         x:Name="TbIsbn"
                         IsReadOnly="True"/>

                <!-- Naziv -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Style="{StaticResource FormLabel}"
                           Text="{DynamicResource Kupovina_LabelNaziv}"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         x:Name="TbNaziv"
                         IsReadOnly="True"/>

                <!-- Ocena -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Style="{StaticResource FormLabel}"
                           Text="{DynamicResource Kupovina_LabelOcena}"/>
                <ComboBox Grid.Row="4" Grid.Column="1"
                          x:Name="CbOcena"
                          SelectionChanged="CbOcena_Changed">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="7"/>
                </ComboBox>

                <!-- Datum -->
                <TextBlock Grid.Row="6" Grid.Column="0"
                           Style="{StaticResource FormLabel}"
                           Text="{DynamicResource Kupovina_LabelDatum}"/>
                <DatePicker Grid.Row="6" Grid.Column="1"
                            x:Name="DpDatum"
                            SelectedDateChanged="DpDatum_Changed"
                            SelectedDateFormat="Short"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="{DynamicResource BtnCancel}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,12,0"
                    IsCancel="True"/>

            <Button x:Name="BtnPotvrdi"
                    Content="{DynamicResource BtnConfirm}"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>