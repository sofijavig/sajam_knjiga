<Window x:Class="WpfClient.Views.PosetilacDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WinVisitorTitle}"
        Width="720" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#F6F7FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#7676A8"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C2185B"/>
        <SolidColorBrush x:Key="Card" Color="White"/>
        <SolidColorBrush x:Key="Text" Color="#111827"/>
        <SolidColorBrush x:Key="SubText" Color="#6B7280"/>
        <SolidColorBrush x:Key="Border" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Hover" Color="#F3F4F6"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="14" ShadowDepth="2" Opacity="0.12"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SubText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFB"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFB"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="12,9"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF1F6"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FCE4EC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Foreground" Value="{StaticResource SubText}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <StackPanel Margin="0,0,20,0" Background="Transparent" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                            <Border x:Name="Underline" Height="3" Background="Transparent"
                                    CornerRadius="2" Margin="0,6,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Underline" Property="Background" Value="{StaticResource Primary}"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Hover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EDEEF2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#AD1457"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Primary}"
                CornerRadius="16"
                Padding="14,12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👤" FontSize="18" Margin="0,0,10,0" Foreground="White"/>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Posetilac_HeaderTitle}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{DynamicResource Posetilac_HeaderSubtitle}" Foreground="#FFE4EC" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource Card}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12"
                Effect="{StaticResource CardShadow}">

            <TabControl>

                <!-- INFORMACIJE -->
                <TabItem Header="{DynamicResource TabInfo}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Background="White"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,10,0,0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource Posetilac_LabelCK}"/>
                                <TextBox x:Name="TbCK" Grid.Row="0" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColFirstName}"/>
                                <TextBox x:Name="TbIme" Grid.Row="1" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColLastName}"/>
                                <TextBox x:Name="TbPrezime" Grid.Row="2" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource Posetilac_LabelBirthDate}"/>
                                <DatePicker x:Name="DpDatRodj" Grid.Row="3" Grid.Column="1" Margin="0,6" SelectedDateChanged="AnyChanged"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColPhone}"/>
                                <TextBox x:Name="TbTelefon" Grid.Row="4" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColEmail}"/>
                                <TextBox x:Name="TbMail" Grid.Row="5" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColStatus}"/>
                                <ComboBox x:Name="CbStatus" Grid.Row="6" Grid.Column="1" Margin="0,6" SelectionChanged="AnyChanged">
                                    <ComboBoxItem Content="{DynamicResource Posetilac_StatusRegular}"/>
                                    <ComboBoxItem Content="{DynamicResource Posetilac_StatusVip}"/>
                                </ComboBox>

                                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColStreet}"/>
                                <TextBox x:Name="TbUlica" Grid.Row="7" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource ColNumber}"/>
                                <TextBox x:Name="TbBroj" Grid.Row="8" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource Posetilac_LabelCity}"/>
                                <TextBox x:Name="TbGrad" Grid.Row="9" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource FormLabel}" Text="{DynamicResource Posetilac_LabelCountry}"/>
                                <TextBox x:Name="TbDrzava" Grid.Row="10" Grid.Column="1" Margin="0,6" TextChanged="AnyChanged"/>
                            </Grid>

                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- KUPLJENE -->
                <TabItem Header="{DynamicResource Posetilac_TabPurchased}">
                    <Border Background="White"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12"
                            Margin="0,10,0,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="BtnPonistiKupovinu"
                                        Content="{DynamicResource Posetilac_BtnCancelPurchase}"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnPonistiKupovinu_Click"
                                        MinWidth="150"/>
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      x:Name="DgKupljene"
                                      AutoGenerateColumns="False">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource Posetilac_ColBook}" Binding="{Binding Knj.Naziv}" Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource ColBooksISBN}" Binding="{Binding Knj.ISBN}" Width="120"/>
                                    <DataGridTextColumn Header="{DynamicResource Posetilac_ColPrice}" Binding="{Binding Knj.Cena, StringFormat={}{0} RSD}" Width="110"/>
                                    <DataGridTextColumn Header="{DynamicResource Posetilac_ColDate}" Binding="{Binding DatKup, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="160"/>
                                    <DataGridTextColumn Header="{DynamicResource Posetilac_ColRating}" Binding="{Binding Ocena}" Width="70"/>
                                    <DataGridTextColumn Header="{DynamicResource Posetilac_ColComment}" Binding="{Binding Komentar}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <TextBlock x:Name="TbProsecnaOcena" Text="{DynamicResource Posetilac_SummaryAvgPlaceholder}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TbPotroseno" Text="{DynamicResource Posetilac_SummarySpentPlaceholder}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>

                        </Grid>
                    </Border>
                </TabItem>

                <!-- ŽELJE -->
                <TabItem Header="{DynamicResource Posetilac_TabWishes}">
                    <Border Background="White"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12"
                            Margin="0,10,0,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <ComboBox x:Name="CbSveKnjige"
                                          Width="420"
                                          Margin="0,0,10,0"
                                          DisplayMemberPath="Naziv"/>
                                <Button Content="{DynamicResource TooltipAdd}"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnDodajZelju_Click"
                                        MinWidth="90"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="{DynamicResource TooltipDelete}"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnObrisiZelju_Click"
                                        MinWidth="110"
                                        Margin="0,0,10,0"/>

                                <Button Content="{DynamicResource Posetilac_BtnPurchase}"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="BtnKupovina_Click"
                                        MinWidth="120"
                                        Margin="0,0,10,0"/>

                                <Button Content="{DynamicResource Posetilac_BtnAuthors}"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BtnAutoriSaZelja_Click"
                                        MinWidth="110"/>
                            </StackPanel>

                            <DataGrid Grid.Row="2"
                                      x:Name="DgZelje"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ColBooksTitle}" Binding="{Binding Naziv}" Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource ColBooksISBN}" Binding="{Binding ISBN}" Width="140"/>
                                    <DataGridTextColumn Header="{DynamicResource Posetilac_ColPublisher}" Binding="{Binding Izdavac}" Width="140"/>
                                    <DataGridTextColumn Header="{DynamicResource Posetilac_ColPrice}" Binding="{Binding Cena}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>

            </TabControl>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{DynamicResource BtnCancel}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0"
                    IsCancel="True"/>

            <Button x:Name="BtnPotvrdi"
                    Content="{DynamicResource BtnConfirm}"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>