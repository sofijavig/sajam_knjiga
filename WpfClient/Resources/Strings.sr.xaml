    <!-- AboutWindow -->
    <sys:String x:Key="About_Title">O aplikaciji</sys:String>
    <sys:String x:Key="About_Header">📚 Sajam Knjiga</sys:String>
    <sys:String x:Key="About_Description">Ova aplikacija omogućava praćenje posetilaca, autora, knjiga i izdavača na Sajmu knjiga. Možete dodavati nove unose, pregledati postojeće i sortirati podatke.</sys:String>
    <sys:String x:Key="About_AuthorsHeader">Autori:</sys:String>

    <sys:String x:Key="About_Author1">Ivo Andrić – Ivo Andrić je bio nobelovac i jedan od najpoznatijih srpskih pisaca. Njegova dela često istražuju istoriju i život običnih ljudi u Bosni.</sys:String>
    <sys:String x:Key="About_Author2">Frederik Bakman – Frederik Bakman je švedski pisac poznat po toplim, duhovitim romanima. Njegove priče kombinuju humor i ljudsku empatiju.</sys:String>
    <sys:String x:Key="About_Author3">Antoan de Sent Egziperi – Francuski pisac i pilot. Najpoznatiji je po knjizi Mali princ, svetskom klasiku.</sys:String>
    <sys:String x:Key="About_Author4">Markus Zusak – Australijski pisac poznat po romanu Kradljivac knjiga.</sys:String>
    <sys:String x:Key="About_Author5">Agata Kristi – Engleska autorka kriminalističkih romana, poznata po zapletima i misterijama.</sys:String>
    <sys:String x:Key="About_Author6">Harper Li – Američka spisateljica poznata po romanu Ubiti pticu rugalicu.</sys:String>
    <sys:String x:Key="About_Author7">Ernest Hemingvej – Američki romanopisac i nobelovac, poznat po jednostavnom i snažnom stilu.</sys:String>
    <sys:String x:Key="About_Author8">Artur Konan Dojl – Tvorac Šerloka Holmsa, majstor detektivskih priča.</sys:String>
    <sys:String x:Key="About_Author9">Fjodor Dostojevski – Ruski romanopisac koji istražuje ljudsku psihu i moral.</sys:String>
    <sys:String x:Key="About_Author10">Emili Bronte – Autorka romana Orkanski visovi.</sys:String>
    <sys:String x:Key="About_Author11">Teri Pratet – Britanski pisac fantazije i humora, poznat po serijalu Diskovni svet.</sys:String>
    <sys:String x:Key="About_Author12">Nil Gejmen – Engleski pisac fantazije i stripova, poznat po mračnim i magičnim pričama.</sys:String>

